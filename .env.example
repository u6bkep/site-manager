# Required: Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_DOMAIN=example.com

# Public URL of this service (used for OAuth redirects)
EXTERNAL_URL=http://localhost:8080

# GitHub integration (choose one: PAT or App)

# Option A: Personal Access Token
# GITHUB_TOKEN=ghp_...

# Option B: GitHub App (org-level, recommended)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_INSTALLATION_ID=12345678

# GITHUB_WEBHOOK_SECRET=

# Server
# BIND_ADDR=0.0.0.0:8080
# DATA_DIR=/var/lib/site-manager
# RUST_LOG=info

# Caddy TLS: "on" for Caddy to manage TLS via ACME (direct exposure),
# "off" (default) when behind a reverse proxy that terminates TLS.
# CADDY_TLS=off
